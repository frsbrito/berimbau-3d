[node name="Label_Titulo" type="Label" parent="Panel/MarginContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 26
text = "Sobre este jogo"
horizontal_alignment = 1

[node name="ScrollContainer" type="ScrollContainer" parent="Panel/MarginContainer/VBoxContainer"]
layout_mode = 2
size_flags_vertical = 3

[node name="Label_Corpo" type="Label" parent="Panel/MarginContainer/VBoxContainer/ScrollContainer"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_font_sizes/font_size = 16
theme_override_constants/line_spacing = 6
text = "Berimbau 3D é um projeto educativo desenvolvido como Trabalho de Conclusão de Curso (TCC) do curso de Sistemas de Informação da Universidade Federal de Ouro Preto (UFOP), sob orientação do Prof. Fernando Bernardes de Oliveira.

O jogo tem como objetivo apresentar, de forma interativa, os toques e timbres do berimbau, um dos instrumentos centrais da capoeira. Aqui você pode explorar livremente os diferentes toques e sons do instrumento, em um espaço de prática livre.

Desenvolvimento: Felipe Ricardo Silva Brito
Motor gráfico: Godot Engine
Instrumentos utilizados: Mestre Canarinho (Capoeira Show, Araucária/PR)
Captação dos sons: Mestre Deividi (União de Itapuã, São Paulo/SP)

O conteúdo histórico e cultural sobre a capoeira e o berimbau apresentado neste simulador está em revisão bibliográfica contínua e pode ser atualizado conforme a pesquisa avança.

Este projeto representa uma etapa de pesquisa acadêmica sobre o uso de jogos digitais no ensino de práticas musicais da cultura popular brasileira."
autowrap_mode = 3

[node name="Sep" type="HSeparator" parent="Panel/MarginContainer/VBoxContainer"]
layout_mode = 2

[node name="BtnVoltar" type="Button" parent="Panel/MarginContainer/VBoxContainer"]
layout_mode = 2
size_flags_horizontal = 4
custom_minimum_size = Vector2(120, 36)
theme_override_styles/normal = SubResource("StyleBoxFlat_act_normal")
theme_override_styles/hover = SubResource("StyleBoxFlat_act_hover")
theme_override_styles/pressed = SubResource("StyleBoxFlat_act_pressed")
text = "← Voltar"

[connection signal="pressed" from="Panel/MarginContainer/VBoxContainer/BtnVoltar" to="." method="_on_btn_voltar_pressed"]
