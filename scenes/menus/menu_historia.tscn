[node name="MenuHistoria" type="Control"]
layout_mode = 3
anchors_preset = 0
script = ExtResource("1_conteudo")
titulos_paginas = ["Origens Ancestrais", "Primeiros Registros no Brasil", "O Encontro com a Roda"]
corpos_paginas = ["O berimbau é um tipo de arco musical, uma das famílias de instrumento mais antigas que existem. Ele nasceu na África: lá, um arco de madeira com uma cabaça (uma espécie de fruta seca e oca) presa na ponta já era tocado há muito tempo, com nomes como hungu ou m'bolumbumba, em Angola. Esse instrumento atravessou o oceano com os africanos trazidos à força para o Brasil como escravos, e foi assim que sua música chegou até aqui.", "No Brasil do século XIX, o berimbau ainda não tinha nada a ver com a capoeira. Ele era tocado por africanos escravizados e, depois, libertos, que vendiam doces e outras coisas pelas ruas do Rio de Janeiro. Batendo no arame, eles chamavam a atenção de quem passava, na hora de vender sua mercadoria. Até hoje existem desenhos da época mostrando essas cenas, como um retratando um vendedor tocando berimbau, feito pelo artista Joaquim Cândido Guillobel.", "Foi na Bahia, entre o fim do século XIX e o começo do século XX, que o berimbau se juntou à capoeira. Antes disso, a roda era acompanhada só por tambor e palma. Aos poucos, o berimbau foi ganhando espaço, até virar quem manda no jogo, decidindo o ritmo, a velocidade e até o estilo da capoeira que está sendo jogada."]

