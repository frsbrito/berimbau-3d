[node name="MenuTimbres" type="Control" unique_id=1096067159]
layout_mode = 3
anchors_preset = 0
script = ExtResource("1_conteudo")
titulos_paginas = ["O que muda de um berimbau para o outro", "Do agudo ao grave"]
corpos_paginas = ["Em uma típica roda de capoeira encontramos até três timbres de berimbau: viola, médio e gunga (ou Berra-Boi). Cada um possui uma afinação específica, e devem estar \"casados\" entre si, isto é, afinados um com o outro, de forma a gerar um som consonante ao serem tocados juntos. Sua sonoridade, mais grave ou mais aguda, é definida pelo tamanho da cabaça, seu posicionamento em relação à verga e o tensionamento do arame.", "A viola é o berimbau que geralmente tem a cabaça menor e de som mais agudo, é usado para fazer variações e repiques por cima do ritmo principal, sempre improvisando. O médio ocupa a faixa intermediária, servindo de ponte entre os dois extremos, a viola aguda e o gunga grave. O gunga, por sua vez, é o que possui a cabaça maior e som imponente, mais grave, costuma carregar a base do ritmo que dá o direcionamento da roda inteira, sejam os outros instrumentos, velocidade rítmica, e estilo de jogo praticado pelos jogadores. Aqui no simulador, alternar entre eles muda só o timbre do som reproduzido, a lógica de toques, dobrão e baqueta continua a mesma."]

