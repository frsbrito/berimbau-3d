[node name="MenuTimbres" type="Control"]
layout_mode = 3
anchors_preset = 0
script = ExtResource("1_conteudo")
titulos_paginas = ["O que muda de um berimbau para o outro", "Do agudo ao grave"]
corpos_paginas = ["No jogo, você escolhe entre três timbres de berimbau: viola, médio e gunga. Essa escolha não é só estética, ela reproduz uma diferença real de afinação entre os berimbaus usados numa roda de verdade. Cada um tem um tamanho de arame e de cabaça que resulta num som diferente, do mais agudo ao mais grave.", "A viola é o berimbau menor e de som mais agudo, geralmente usado pra fazer variações e repiques por cima do ritmo principal. O médio ocupa a faixa intermediária, servindo de ponte entre os dois extremos. Já o gunga, maior e de som mais grave, costuma carregar a base do ritmo que dá o tom da roda inteira. No simulador, alternar entre eles muda só o timbre do som reproduzido, a lógica de toques, dobrão e baqueta continua a mesma."]

